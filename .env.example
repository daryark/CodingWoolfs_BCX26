VOYAGE_API_KEY=your-voyage-api-key-here
DB_PASSWORD=your-mongodb-password-here

# Free tier (no payment method): 3 RPM, 10K TPM — defaults below are tuned for that
# With payment method on voyage-3.5: 2000 RPM, 8M TPM — then use e.g. EMBED_BATCH_SIZE=64 EMBED_RATE_LIMIT_WAIT=1
# EMBED_BATCH_SIZE=4
# EMBED_RATE_LIMIT_WAIT=25
# EMBED_MAX_TOKENS_PER_REQUEST=8000
# EMBED_MAX_TOKENS_SINGLE=8000
